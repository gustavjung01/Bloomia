{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bloomia",
  "version": "0.1.0",
  "identifier": "com.bloomia.desktop",
  "build": {
    "beforeDevCommand": "npm run prepare:assets && npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run prepare:assets && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bloomia",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://pub-ddb20c1432674f3d97ae6d00d291bbb9.r2.dev/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1Mjc3ODc3QTU1MEM4QTEKUldTaHlGQ2xkM2dubGJTY05GV0lXNVVzYWxHMitnV2V5UFA2WDhSK29pZjBnTHBTVXhRUmRCbnUK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "publisher": "Bloomia",
    "category": "Business",
    "shortDescription": "Bloomia Studio POS for florist shops",
    "longDescription": "Bloomia helps florist shops sell flowers, manage orders, inventory, recipes and local reports.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/installer-header.bmp",
        "uninstallerHeaderImage": "installer/installer-header.bmp",
        "sidebarImage": "installer/installer-sidebar.bmp",
        "installMode": "both",
        "startMenuFolder": "Bloomia",
        "displayLanguageSelector": false,
        "languages": [
          "English"
        ]
      }
    }
  }
}
