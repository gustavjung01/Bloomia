{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bloomia",
  "version": "0.1.0",
  "identifier": "com.bloomia.desktop",
  "build": {
    "beforeDevCommand": "npm run prepare:assets && npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run prepare:assets && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bloomia",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "publisher": "Bloomia",
    "category": "Business",
    "shortDescription": "Bloomia Studio POS for florist shops",
    "longDescription": "Bloomia helps florist shops sell flowers, manage orders, inventory, recipes and local reports.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/installer-header.bmp",
        "uninstallerHeaderImage": "installer/installer-header.bmp",
        "sidebarImage": "installer/installer-sidebar.bmp",
        "installMode": "both",
        "startMenuFolder": "Bloomia",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    }
  }
}
